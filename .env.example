# Supabase (projeto erp-emt, regiao sa-east-1)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Service role: SOMENTE no servidor (convites de usuario, operacoes admin).
# Nunca exponha com prefixo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL publica do app (links de convite e redirects de auth).
# Em producao, use a URL do deploy na Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
